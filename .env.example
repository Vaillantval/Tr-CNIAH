# ============================================================
# CNIAH — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Django
DEBUG=1
SECRET_KEY=changez-cette-cle-secrete-en-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
POSTGRES_DB=cniah_db
POSTGRES_USER=cniah_user
POSTGRES_PASSWORD=cniah_password
DATABASE_URL=postgresql://cniah_user:cniah_password@db:5432/cniah_db

# ─── Email ───────────────────────────────────────────────────
# Développement : console (pas d'envoi réel)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production — Resend (gratuit: 3 000 emails/mois)
# 1. Créer un compte sur https://resend.com
# 2. Vérifier le domaine cniah.ht dans Resend → Domains
# 3. Générer une clé API dans Resend → API Keys
# 4. Remplacer les valeurs ci-dessous et changer EMAIL_BACKEND
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx   ← clé API Resend
#
# Alternative: Brevo (300 emails/jour gratuit — https://brevo.com)
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=votre@email.com
# EMAIL_HOST_PASSWORD=<SMTP_KEY_BREVO>

EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@cniah.ht

# Emails de notification admin (séparés par virgule)
ADMIN_NOTIFY_EMAIL=secretariat@cniah.ht

# URL publique du site (utilisée dans les emails et les QR codes)
SITE_URL=http://localhost:8002

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
