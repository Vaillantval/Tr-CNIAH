# ============================================================
# CNIAH — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Django
DEBUG=1
SECRET_KEY=changez-cette-cle-secrete-en-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
POSTGRES_DB=cniah_db
POSTGRES_USER=cniah_user
POSTGRES_PASSWORD=cniah_password
DATABASE_URL=postgresql://cniah_user:cniah_password@db:5432/cniah_db

# Email (laisser vide pour utiliser la console en développement)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@cniah.ht

# URL publique du site (utilisée dans les emails et les QR codes)
SITE_URL=http://localhost:8002

# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
